<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace必须与Mapper接口全类名一致 -->
<mapper namespace="org.example.Demo.mapper.UserMapper">

    <select id="pageUserMessage" resultType="org.example.Demo.VO.UserVO.UserMessageVO">
        select * from user
        <where>
            <if test="name != null">
                AND user.name like concat("%",#{name},"%")
            </if>
        </where>
    </select>
    <select id="selectList" resultType="org.example.Demo.entity.User.User">
        select * from user
    </select>


    <update id="update">
        update user
        <set>
            <if test="name != null">name=#{name},</if>
            <if test="mail != null">mail=#{mail},</if>
            <if test="number != null">number=#{number},</if>
            <if test="mobile != null">mobile=#{mobile},</if>
            <if test="password != null">password=#{password},</if>
        </set>
        <where>
            id=#{id}
        </where>
    </update>
    <update id="updateUserStatus" parameterType="org.example.Demo.DTO.UserDTO.UpdateUserStatus">
        UPDATE `user`
        SET status_enum = #{status}
        WHERE id = #{id}
    </update>
</mapper>